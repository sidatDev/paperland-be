  author          User              @relation("KbArticleAuthor", fields: [authorId], references: [id])
  revisions       KbArticleRevision[]
  feedbacks       KbFeedback[]

  @@index([categoryId])
  @@index([status, publishedAt])
  @@index([slug])
  @@map("kb_articles")
}

model KbArticleRevision {
  id           String    @id @default(uuid())
  articleId    String    @map("article_id")
  contentJson  Json?     @map("content_json") @db.JsonB
  contentText  String?   @map("content_text")
  renderedHtml String?   @map("rendered_html")
  title        String
  version      Int
  changeNote   String?   @map("change_note")
  createdById  String    @map("created_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  article      KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdBy    User      @relation("KbRevisionCreator", fields: [createdById], references: [id])

  @@index([articleId])
  @@map("kb_article_revisions")
}

model KbFaq {
  id          String       @id @default(uuid())
  question    String
  answerJson  Json?        @map("answer_json") @db.JsonB
  answerText  String?      @map("answer_text")
  position    Int          @default(0)
  isActive    Boolean      @default(true) @map("is_active")
  categoryId  String?      @map("category_id")
  tags        String[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  category    KbCategory?  @relation(fields: [categoryId], references: [id])
  feedbacks   KbFeedback[]

  @@index([categoryId])
  @@map("kb_faqs")
}

model KbFeedback {
  id         String     @id @default(uuid())
  articleId  String?    @map("article_id")
  faqId      String?    @map("faq_id")
  helpful    Boolean
  ipAddress  String?    @map("ip_address")
  userAgent  String?    @map("user_agent")
  createdAt  DateTime   @default(now()) @map("created_at")

  article    KbArticle? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  faq        KbFaq?     @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([faqId])
  @@map("kb_feedback")
}

model KbMedia {
  id        String   @id @default(uuid())
  filename  String
  url       String   @unique
  mimetype  String
  size      Int
  key       String   @unique
  folder    String   @default("knowledge-base")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("kb_media_assets")
}
