generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Knowledge Base Enums ────────────────────────────────────────────

enum KbArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum KbVisibility {
  PUBLIC
  PRIVATE
  ADMIN
  VENDOR
  CUSTOMER
}

model Currency {
  id                String         @id @default(uuid())
  code              String         @unique
  name              String
  symbol            String
  decimalPlaces     Int            @default(2) @map("decimal_places")
  isActive          Boolean        @default(true) @map("is_active")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")
  b2bProfiles       B2BProfile[]
  countries         Country[]
  exchangeRatesFrom ExchangeRate[] @relation("FromCurrency")
  exchangeRatesTo   ExchangeRate[] @relation("ToCurrency")
  orders            Order[]
  prices            Price[]
  transactions      Transaction[]
  bankAccounts      BankAccount[]

  @@map("currencies")
}

model Country {
  id            String         @id @default(uuid())
  code          String         @unique
  name          String
  currencyId    String         @map("currency_id")
  taxRate       Decimal        @default(0) @db.Decimal(5, 2)
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  addresses     Address[]
  currency      Currency       @relation(fields: [currencyId], references: [id])
  shippingZones ShippingZone[]

  @@index([currencyId])
  @@map("countries")
}

model ExchangeRate {
  id             String    @id @default(uuid())
  fromCurrencyId String    @map("from_currency_id")
  toCurrencyId   String    @map("to_currency_id")
  rate           Decimal   @db.Decimal(10, 6)
  validFrom      DateTime  @map("valid_from")
  validTo        DateTime? @map("valid_to")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  fromCurrency   Currency  @relation("FromCurrency", fields: [fromCurrencyId], references: [id])
  toCurrency     Currency  @relation("ToCurrency", fields: [toCurrencyId], references: [id])

  @@unique([fromCurrencyId, toCurrencyId, validFrom])
  @@index([fromCurrencyId])
  @@index([toCurrencyId])
  @@index([validFrom, validTo])
  @@map("exchange_rates")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  title           String
  key             String           @unique
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at")
  assignedBy   String?    @map("assigned_by")
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at")
  assignedBy   String?    @map("assigned_by")
  permission   Permission @relation(fields: [permissionId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model User {
  id                    String               @id @default(uuid())
  email                 String               @unique
  passwordHash          String               @map("password_hash")
  firstName             String?              @map("first_name")
  lastName              String?              @map("last_name")
  roleId                String               @map("role_id")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  isActive              Boolean              @default(true) @map("is_active")
  b2bProfileId          String?              @map("b2b_profile_id")
  phoneNumber           String?              @map("phone_number")
  deletedAt             DateTime?            @map("deleted_at")
  companyName           String?              @map("company_name")
  licenseNumber         String?              @map("license_number")
  accountStatus         String               @default("PENDING") @map("account_status")
  emailVerified         Boolean              @default(false) @map("email_verified")
  otpCode               String?              @map("otp_code")
  otpExpiry             DateTime?            @map("otp_expiry")
  phoneCountryCode      String?              @map("phone_country_code")
  preferences           Json?                @default("{}")
  profilePictureUrl     String?              @map("profile_picture_url")
  dateOfBirth           DateTime?            @map("date_of_birth")
  pendingEmail          String?              @map("pending_email")
  state                 String?
  zipCode               String?              @map("zip_code")
  createdById           String?              @map("created_by_id")
  lastLoginAt           DateTime?            @map("last_login_at")
  lastPasswordChangedAt DateTime?            @map("last_password_changed_at")
  lockedAt              DateTime?            @map("locked_at")
  companyId             String?              @map("company_id")
  addresses             Address[]
  auditLogs             AuditLog[]
  b2bCompanyDetails     B2BCompanyDetails?
  b2b_team_members      b2b_team_members?
  blogPosts             BlogPost[]
  carts                 Cart[]
  cmsLogs               CMSLog[]
  cmsVersions           CMSVersion[]
  statusHistory         OrderStatusHistory[]
  orders                Order[]
  purchase_orders       purchase_orders[]
  reportLogs            ReportLog[]
  returnRequests        ReturnRequest[]
  helpfulVotes          ReviewHelpfulVote[]
  reviews               Review[]
  rfqs                  RFQ[]
  assignedTickets       SupportTicket[]      @relation("AssignedTickets")
  tickets               SupportTicket[]      @relation("UserTickets")
  messages              TicketMessage[]
  transactions          Transaction[]
  permissions           UserPermission[]
  b2bProfile            B2BProfile?          @relation(fields: [b2bProfileId], references: [id])
  company               Company?             @relation(fields: [companyId], references: [id])
  role                  Role                 @relation(fields: [roleId], references: [id])
  wishlists             Wishlist?
  priceUpdateLogs       PriceUpdateLog[]
  kbArticles            KbArticle[]          @relation("KbArticleAuthor")
  kbRevisions           KbArticleRevision[]  @relation("KbRevisionCreator")

  @@map("users")
}

model Address {
  id        String    @id @default(uuid())
  userId    String?   @map("user_id")
  type      String    @default("SHIPPING")
  isDefault Boolean   @default(false) @map("is_default")
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  company   String?
  street1   String    @map("street_1")
  street2   String?   @map("street_2")
  city      String
  state     String?
  zipCode   String    @map("zip_code")
  phone     String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  countryId String    @map("country_id")
  country   Country   @relation(fields: [countryId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])
  orders    Order[]

  @@index([countryId])
  @@map("addresses")
}

model B2BCompanyDetails {
  id                            String   @id @default(uuid())
  userId                        String   @unique @map("user_id")
  companyName                   String   @map("company_name")
  registrationCountry           String   @map("registration_country")
  taxId                         String   @map("tax_id")
  registrationDate              DateTime @map("registration_date")
  companyAddress                String   @map("company_address")
  registrationProofUrl          String?  @map("registration_proof_url")
  doingBusinessAs               String?  @map("doing_business_as")
  primaryContactName            String   @map("primary_contact_name")
  jobTitle                      String   @map("job_title")
  contactPhone                  String   @map("contact_phone")
  contactCountryCode            String   @map("contact_country_code")
  billingEmail                  String   @map("billing_email")
  shippingAddress               String   @map("shipping_address")
  apContactName                 String   @map("ap_contact_name")
  apPhone                       String   @map("ap_phone")
  apCountryCode                 String   @map("ap_country_code")
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")
  registrationProofUrls         String[] @default([]) @map("registration_proof_urls")
  authorizedRepresentativeEmail String?  @map("authorized_rep_email")
  authorizedRepresentativeName  String?  @map("authorized_rep_name")
  registeredLegalEntity         String?  @map("registered_legal_entity")
  user                          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("b2b_company_details")
}

model B2BProfile {
  id                String                    @id @default(uuid())
  companyName       String                    @map("company_name")
  taxId             String?                   @map("tax_id")
  creditLimit       Decimal                   @default(0) @map("credit_limit") @db.Decimal(12, 2)
  usedCredit        Decimal                   @default(0) @map("used_credit") @db.Decimal(12, 2)
  paymentTerms      String?                   @map("payment_terms")
  status            String                    @default("PENDING")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")
  deletedAt         DateTime?                 @map("deleted_at")
  currencyId        String?                   @map("currency_id")
  rejectionReason   String?                   @map("rejection_reason")
  adminNotes        String?                   @map("admin_notes")
  discountTierId    String?                   @map("discount_tier_id")
  companyId         String?                   @map("company_id")
  company           Company?                  @relation(fields: [companyId], references: [id])
  currency          Currency?                 @relation(fields: [currencyId], references: [id])
  discountTier      DiscountTier?             @relation(fields: [discountTierId], references: [id])
  b2b_team_members  b2b_team_members[]
  custom_catalogs   custom_catalogs[]
  discountOverrides ProductDiscountOverride[]
  purchase_orders   purchase_orders[]
  securityDeposits  SecurityDeposit[]
  users             User[]

  @@index([currencyId])
  @@index([discountTierId])
  @@map("b2b_profiles")
}

model Category {
  id               String           @id @default(uuid())
  name             String
  description      String?
  slug             String?          @unique
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")
  imageUrl         String?          @map("image_url")
  parentId         String?          @map("parent_id")
  position         Int              @default(0)
  normalizedName   String?          @unique @map("normalized_name")
  showOnHomepage   Boolean          @default(false) @map("show_on_homepage")
  homepageOrder    Int              @default(0) @map("homepage_order")
  homepageImage    String?          @map("homepage_image")
  parent           Category?        @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subCategories    Category[]       @relation("CategoryHierarchy")
  couponCategories CouponCategory[]
  products         Product[]
  Promotion        Promotion[]

  @@map("categories")
}

model Brand {
  id             String      @id @default(uuid())
  name           String      @unique
  description    String?
  logoUrl        String?     @map("logo_url")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")
  slug           String?     @unique
  normalizedName String?     @unique @map("normalized_name")
  products       Product[]
  Promotion      Promotion[]

  @@map("brands")
}

model Industry {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  slug        String?           @unique
  logoUrl     String?           @map("logo_url")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")
  products    ProductIndustry[]

  @@map("industries")
}

model Grade {
  id          String         @id @default(uuid())
  name        String         @unique
  slug        String         @unique
  description String?
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  products    ProductGrade[]

  @@map("grades")
}

model ProductGrade {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  gradeId   String   @map("grade_id")
  createdAt DateTime @default(now()) @map("created_at")
  grade     Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, gradeId])
  @@index([productId])
  @@index([gradeId])
  @@map("product_grades")
}

model Product {
  id                   String                    @id @default(uuid())
  name                 String
  sku                  String                    @unique
  description          String?
  imageUrl             String?                   @map("image_url")
  specifications       Json?
  isActive             Boolean                   @default(true) @map("is_active")
  categoryId           String                    @map("category_id")
  brandId              String                    @map("brand_id")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")
  deletedAt            DateTime?                 @map("deleted_at")
  length               String?
  weight               String?
  images               String[]
  isFeatured           Boolean                   @default(false) @map("is_featured")
  volume               String?
  width                String?
  isVisibleOnEcommerce Boolean                   @default(true) @map("is_ecommerce_visible")
  slug                 String?                   @unique
  fullDescription      String?                   @map("full_description")
  price                Decimal?                  @db.Decimal(10, 2)
  status               String                    @default("Draft")
  groupNumber          String?                   @map("group_number")
  groupId              String?                   @map("group_id")
  parentId             String?                   @map("parent_id")
  variantAttributes    Json?                     @map("variant_attributes")
  variantOptions       Json?                     @map("variant_options")
  costPrice            Decimal?                  @map("cost_price") @db.Decimal(10, 2)
  batches              Batch[]
  cartItems            CartItem[]
  catalogPricing       CatalogPricing[]
  catalogProducts      CatalogProduct[]
  catalogVariants      CatalogVariant[]
  couponProducts       CouponProduct[]
  crossReferences      CrossReference[]          @relation("SourceProduct")
  crossReferencedBy    CrossReference[]          @relation("TargetProduct")
  custom_catalog_items custom_catalog_items[]
  homepageItems        HomepageSectionItem[]
  orderItems           OrderItem[]
  prices               Price[]
  discountOverrides    ProductDiscountOverride[]
  grades               ProductGrade[]
  industries           ProductIndustry[]
  sourceRelations      ProductRelation[]         @relation("SourceRelations")
  targetRelations      ProductRelation[]         @relation("TargetRelations")
  brand                Brand                     @relation(fields: [brandId], references: [id])
  category             Category                  @relation(fields: [categoryId], references: [id])
  parent               Product?                  @relation("ProductVariants", fields: [parentId], references: [id])
  variants             Product[]                 @relation("ProductVariants")
  returnItems          ReturnItem[]
  reviews              Review[]
  rfqItems             RFQItem[]
  stocks               Stock[]
  wishlistItems        WishlistItem[]
  Promotion            Promotion[]
  priceUpdateLogs      PriceUpdateLog[]

  @@map("products")
}

model ProductIndustry {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  industryId String   @map("industry_id")
  createdAt  DateTime @default(now()) @map("created_at")
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, industryId])
  @@index([productId])
  @@index([industryId])
  @@map("product_industries")
}

model Price {
  id             String   @id @default(uuid())
  productId      String   @map("product_id")
  createdAt      DateTime @default(now())
  currencyId     String   @map("currency_id")
  isActive       Boolean  @default(true)
  metadata       Json?
  priceRetail    Decimal  @default(0) @db.Decimal(10, 2)
  priceSpecial   Decimal? @db.Decimal(10, 2)
  priceWholesale Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt      DateTime @updatedAt
  currency       Currency @relation(fields: [currencyId], references: [id])
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([currencyId])
  @@map("prices")
}

model Batch {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  sku       String?
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(true) @map("is_active")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isActive])
  @@map("batches")
}

model Warehouse {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  city      String
  country   String    @default("PK")
  address   String?
  isActive  Boolean   @default(true) @map("is_active")
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  type      String    @default("WAREHOUSE")
  orders    Order[]
  stocks    Stock[]

  @@map("warehouses")
}

model Stock {
  id           String     @id @default(uuid())
  productId    String     @map("product_id")
  locationId   String     @map("location_id")
  qty          Int        @default(0)
  updatedAt    DateTime   @updatedAt @map("updated_at")
  warehouseId  String?    @map("warehouse_id")
  reservedQty  Int        @default(0) @map("reserved_qty")
  reorderLevel Int        @default(10) @map("reorder_level")
  product      Product    @relation(fields: [productId], references: [id])
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@map("stocks")
}

model Review {
  id               String              @id @default(uuid())
  userId           String?             @map("user_id")
  productId        String              @map("product_id")
  rating           Int
  comment          String?
  images           String[]
  isVerified       Boolean             @default(false) @map("is_verified")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  deletedAt        DateTime?           @map("deleted_at")
  customerImageUrl String?             @map("customer_image_url")
  customerLocation String?             @map("customer_location")
  customerName     String?             @map("customer_name")
  status           String              @default("PENDING")
  helpfulCount     Int                 @default(0) @map("helpful_count")
  helpfulVotes     ReviewHelpfulVote[]
  product          Product             @relation(fields: [productId], references: [id])
  user             User?               @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model ReviewHelpfulVote {
  id        String   @id @default(uuid())
  reviewId  String   @map("review_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@map("review_helpful_votes")
}

model ProductImportLog {
  id          String    @id @default(uuid())
  triggeredBy String?   @map("triggered_by")
  status      String    @default("QUEUED")
  createdAt   DateTime  @default(now()) @map("created_at")
  added       Int       @default(0)
  completedAt DateTime? @map("completed_at")
  duration    Int?
  errorsJson  Json?     @map("errors_json")
  failed      Int       @default(0)
  fileName    String?   @map("file_name")
  filePath    String?   @map("file_path")
  mode        String    @default("UPSERT")
  progress    Int       @default(0)
  skipped     Int       @default(0)
  stockMode   String    @default("OVERWRITE")
  totalRows   Int       @default(0) @map("total_rows")
  updated     Int       @default(0)

  @@index([createdAt])
  @@index([status])
  @@map("product_import_logs")
}

model Order {
  id                     String               @id @default(uuid())
  orderNumber            String               @unique @map("order_number")
  userId                 String?              @map("user_id")
  status                 String               @default("PENDING")
  totalAmount            Decimal              @map("total_amount") @db.Decimal(12, 2)
  taxAmount              Decimal              @map("tax_amount") @db.Decimal(12, 2)
  shippingAmount         Decimal              @map("shipping_amount") @db.Decimal(12, 2)
  addressId              String               @map("address_id")
  paymentStatus          String               @default("UNPAID") @map("payment_status")
  paymentMethod          String?              @map("payment_method")
  trackingNumber         String?              @map("tracking_number")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  deletedAt              DateTime?            @map("deleted_at")
  billingSnapshot        Json?                @map("billing_snapshot")
  currencyId             String               @map("currency_id")
  notes                  Json?
  orderContext           Json?                @map("order_context")
  paymentDetails         Json?                @map("payment_details")
  pricingSummary         Json?                @map("pricing_summary")
  shippingDetails        Json?                @map("shipping_details")
  shippingSnapshot       Json?                @map("shipping_snapshot")
  courierPartner         String?              @map("courier_partner")
  creditAPR              Decimal?             @map("credit_apr") @db.Decimal(5, 2)
  creditTerm             Int?                 @map("credit_term")
  deliveryMethod         String?              @map("delivery_method")
  downPayment            Decimal?             @map("down_payment") @db.Decimal(10, 2)
  estimatedDeliveryDate  DateTime?            @map("estimated_delivery_date")
  transactionRef         String?              @map("transaction_ref")
  deliveredDate          DateTime?            @map("delivered_date")
  processingDate         DateTime?            @map("processing_date")
  shippedDate            DateTime?            @map("shipped_date")
  trackingTimeline       Json?                @map("tracking_timeline")
  couponId               String?              @map("coupon_id")
  shipperBookingId       String?              @map("shipper_booking_id")
  guestEmail             String?              @map("guest_email")
  guestPhone             String?              @map("guest_phone")
  isGuestOrder           Boolean              @default(false) @map("is_guest_order")
  guestToken             String?              @map("guest_token")
  courierProviderId      String?              @map("courier_provider_id")
  deliveryStatus         String?              @map("delivery_status")
  fulfillmentWarehouseId String?              @map("fulfillment_warehouse_id")
  logisticsType          String?              @map("logistics_type")
  riderId                String?              @map("rider_id")
  trackingResponseJson   Json?                @map("tracking_response_json")
  trackingStatus         String?              @map("tracking_status")
  isManualLogistics      Boolean              @default(false) @map("is_manual_logistics")
  cancellationReason     String?              @map("cancellation_reason")
  cancelRequestedAt      DateTime?            @map("cancel_requested_at")
  totalCost              Decimal?             @map("total_cost") @db.Decimal(12, 2)
  totalExpenses          Decimal?             @map("total_expenses") @db.Decimal(12, 2)
  items                  OrderItem[]
  history                OrderStatusHistory[]
  address                Address              @relation(fields: [addressId], references: [id])
  coupon                 Coupon?              @relation(fields: [couponId], references: [id])
  courierProvider        CourierProvider?     @relation(fields: [courierProviderId], references: [id])
  currency               Currency             @relation(fields: [currencyId], references: [id])
