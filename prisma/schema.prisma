generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Currency {
  id                String         @id @default(uuid())
  code              String         @unique
  name              String
  symbol            String
  decimalPlaces     Int            @default(2) @map("decimal_places")
  isActive          Boolean        @default(true) @map("is_active")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")
  b2bProfiles       B2BProfile[]
  countries         Country[]
  exchangeRatesFrom ExchangeRate[] @relation("FromCurrency")
  exchangeRatesTo   ExchangeRate[] @relation("ToCurrency")
  orders            Order[]
  prices            Price[]
  transactions      Transaction[]

  @@map("currencies")
}

model Country {
  id            String         @id @default(uuid())
  code          String         @unique
  name          String
  currencyId    String         @map("currency_id")
  taxRate       Decimal        @default(0) @db.Decimal(5, 2)
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  addresses     Address[]
  currency      Currency       @relation(fields: [currencyId], references: [id])
  shippingZones ShippingZone[]

  @@index([currencyId])
  @@map("countries")
}

model ExchangeRate {
  id             String    @id @default(uuid())
  fromCurrencyId String    @map("from_currency_id")
  toCurrencyId   String    @map("to_currency_id")
  rate           Decimal   @db.Decimal(10, 6)
  validFrom      DateTime  @map("valid_from")
  validTo        DateTime? @map("valid_to")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  fromCurrency   Currency  @relation("FromCurrency", fields: [fromCurrencyId], references: [id])
  toCurrency     Currency  @relation("ToCurrency", fields: [toCurrencyId], references: [id])

  @@unique([fromCurrencyId, toCurrencyId, validFrom])
  @@index([fromCurrencyId])
  @@index([toCurrencyId])
  @@index([validFrom, validTo])
  @@map("exchange_rates")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  title           String
  key             String           @unique
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at")
  assignedBy   String?    @map("assigned_by")
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at")
  assignedBy   String?    @map("assigned_by")
  permission   Permission @relation(fields: [permissionId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model User {
  id                    String               @id @default(uuid())
  email                 String               @unique
  passwordHash          String               @map("password_hash")
  firstName             String?              @map("first_name")
  lastName              String?              @map("last_name")
  roleId                String               @map("role_id")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  isActive              Boolean              @default(true) @map("is_active")
  b2bProfileId          String?              @map("b2b_profile_id")
  phoneNumber           String?              @map("phone_number")
  deletedAt             DateTime?            @map("deleted_at")
  companyName           String?              @map("company_name")
  licenseNumber         String?              @map("license_number")
  lastLoginAt           DateTime?            @map("last_login_at")
  lastPasswordChangedAt DateTime?            @map("last_password_changed_at")
  lockedAt              DateTime?            @map("locked_at")
  createdById           String?              @map("created_by_id")
  accountStatus         String               @default("PENDING") @map("account_status")
  emailVerified         Boolean              @default(false) @map("email_verified")
  otpCode               String?              @map("otp_code")
  otpExpiry             DateTime?            @map("otp_expiry")
  phoneCountryCode      String?              @map("phone_country_code")
  preferences           Json?                @default("{}")
  profilePictureUrl     String?              @map("profile_picture_url")
  dateOfBirth           DateTime?            @map("date_of_birth")
  pendingEmail          String?              @map("pending_email")
  state                 String?
  zipCode               String?              @map("zip_code")
  addresses             Address[]
  auditLogs             AuditLog[]
  b2bCompanyDetails     B2BCompanyDetails?
  b2b_team_members      b2b_team_members?
  blogPosts             BlogPost[]
  carts                 Cart[]
  cmsLogs               CMSLog[]
  cmsVersions           CMSVersion[]
  statusHistory         OrderStatusHistory[]
  orders                Order[]
  purchase_orders       purchase_orders[]
  reportLogs            ReportLog[]
  reviews               Review[]
  rfqs                  RFQ[]
  tickets               SupportTicket[]      @relation("UserTickets")
  assignedTickets       SupportTicket[]      @relation("AssignedTickets")
  messages              TicketMessage[]
  transactions          Transaction[]
  permissions           UserPermission[]
  b2bProfile            B2BProfile?          @relation(fields: [b2bProfileId], references: [id])
  role                  Role                 @relation(fields: [roleId], references: [id])
  wishlists             Wishlist?
  returnRequests        ReturnRequest[]

  @@map("users")
}

model Address {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String    @default("SHIPPING")
  isDefault Boolean   @default(false) @map("is_default")
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  company   String?
  street1   String    @map("street_1")
  street2   String?   @map("street_2")
  city      String
  state     String?
  zipCode   String    @map("zip_code")
  phone     String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  countryId String    @map("country_id")
  country   Country   @relation(fields: [countryId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  orders    Order[]

  @@index([countryId])
  @@map("addresses")
}

model B2BCompanyDetails {
  id                            String   @id @default(uuid())
  userId                        String   @unique @map("user_id")
  companyName                   String   @map("company_name")
  registrationCountry           String   @map("registration_country")
  taxId                         String   @map("tax_id")
  registrationDate              DateTime @map("registration_date")
  companyAddress                String   @map("company_address")
  registrationProofUrl          String?  @map("registration_proof_url")
  doingBusinessAs               String?  @map("doing_business_as")
  primaryContactName            String   @map("primary_contact_name")
  jobTitle                      String   @map("job_title")
  contactPhone                  String   @map("contact_phone")
  contactCountryCode            String   @map("contact_country_code")
  billingEmail                  String   @map("billing_email")
  shippingAddress               String   @map("shipping_address")
  apContactName                 String   @map("ap_contact_name")
  apPhone                       String   @map("ap_phone")
  apCountryCode                 String   @map("ap_country_code")
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")
  registrationProofUrls         String[] @default([]) @map("registration_proof_urls")
  authorizedRepresentativeEmail String?  @map("authorized_rep_email")
  authorizedRepresentativeName  String?  @map("authorized_rep_name")
  registeredLegalEntity         String?  @map("registered_legal_entity")
  user                          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("b2b_company_details")
}

model B2BProfile {
  id              String    @id @default(uuid())
  companyName     String    @map("company_name")
  taxId           String?   @map("tax_id")
  creditLimit     Decimal   @default(0) @map("credit_limit") @db.Decimal(12, 2)
  usedCredit      Decimal   @default(0) @map("used_credit") @db.Decimal(12, 2)
  paymentTerms    String?   @map("payment_terms")
  status          String    @default("PENDING")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  currencyId      String?   @map("currency_id")
  rejectionReason String?   @map("rejection_reason")
  adminNotes      String?   @map("admin_notes")
  discountTierId  String?   @map("discount_tier_id")

  currency          Currency?                 @relation(fields: [currencyId], references: [id])
  discountTier      DiscountTier?             @relation(fields: [discountTierId], references: [id])
  b2b_team_members  b2b_team_members[]
  custom_catalogs   custom_catalogs[]
  purchase_orders   purchase_orders[]
  discountOverrides ProductDiscountOverride[]
  users             User[]

  @@index([currencyId])
  @@index([discountTierId])
  @@map("b2b_profiles")
}

model Category {
  id            String     @id @default(uuid())
  name          String     @unique
  description   String?
  slug          String?    @unique
  isActive      Boolean    @default(true) @map("is_active")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")
  imageUrl      String?    @map("image_url")
  parentId      String?    @map("parent_id")
  parent        Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subCategories Category[] @relation("CategoryHierarchy")
  products      Product[]

  @@map("categories")
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  logoUrl     String?   @map("logo_url")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  slug        String?   @unique
  products    Product[]

  @@map("brands")
}

model Industry {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  slug        String?           @unique
  logoUrl     String?           @map("logo_url")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")
  products    ProductIndustry[]

  @@map("industries")
}

model Product {
  id                   String                    @id @default(uuid())
  name                 String
  sku                  String                    @unique
  description          String?
  fullDescription      String?                   @map("full_description")
  price                Decimal?                  @db.Decimal(10, 2)
  imageUrl             String?                   @map("image_url")
  images               String[]
  specifications       Json?
  status               String                    @default("Draft")
  groupNumber          String?                   @map("group_number")
  groupId              String?                   @map("group_id")
  isFeatured           Boolean                   @default(false) @map("is_featured")
  isVisibleOnEcommerce Boolean                   @default(true) @map("is_ecommerce_visible")
  slug                 String?                   @unique
  length               String?
  width                String?
  weight               String?
  volume               String?
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")
  deletedAt            DateTime?                 @map("deleted_at")
  isActive             Boolean                   @default(true) @map("is_active")
  categoryId           String                    @map("category_id")
  brandId              String                    @map("brand_id")
  batches              Batch[]
  cartItems            CartItem[]
  crossReferences      CrossReference[]          @relation("SourceProduct")
  crossReferencedBy    CrossReference[]          @relation("TargetProduct")
  custom_catalog_items custom_catalog_items[]
  homepageItems        HomepageSectionItem[]
  orderItems           OrderItem[]
  prices               Price[]
  industries           ProductIndustry[]
  brand                Brand                     @relation(fields: [brandId], references: [id])
  category             Category                  @relation(fields: [categoryId], references: [id])
  reviews              Review[]
  rfqItems             RFQItem[]
  stocks               Stock[]
  wishlistItems        WishlistItem[]
  discountOverrides    ProductDiscountOverride[]
  returnItems          ReturnItem[]

  // Variants Support
  parentId          String?      @map("parent_id")
  parent            Product?     @relation("ProductVariants", fields: [parentId], references: [id])
  variants          Product[]    @relation("ProductVariants")
  variantOptions    Json?        @map("variant_options")
  variantAttributes Json?        @map("variant_attributes")

  @@map("products")
}

model ProductIndustry {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  industryId String   @map("industry_id")
  createdAt  DateTime @default(now()) @map("created_at")
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, industryId])
  @@index([productId])
  @@index([industryId])
  @@map("product_industries")
}

model Price {
  id             String   @id @default(uuid())
  productId      String   @map("product_id")
  createdAt      DateTime @default(now())
  currencyId     String   @map("currency_id")
  isActive       Boolean  @default(true)
  metadata       Json?
  priceRetail    Decimal  @default(0) @db.Decimal(10, 2)
  priceSpecial   Decimal? @db.Decimal(10, 2)
  priceWholesale Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt      DateTime @updatedAt
  currency       Currency @relation(fields: [currencyId], references: [id])
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([currencyId])
  @@map("prices")
}

model Batch {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  sku       String?
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(true) @map("is_active")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isActive])
  @@map("batches")
}

model Warehouse {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  city      String
  country   String    @default("PK")
  address   String?
  isActive  Boolean   @default(true) @map("is_active")
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  stocks    Stock[]

  @@map("warehouses")
}

model Stock {
  id           String     @id @default(uuid())
  productId    String     @map("product_id")
  locationId   String     @map("location_id")
  qty          Int        @default(0)
  updatedAt    DateTime   @updatedAt @map("updated_at")
  warehouseId  String?    @map("warehouse_id")
  reservedQty  Int        @default(0) @map("reserved_qty")
  reorderLevel Int        @default(10) @map("reorder_level")
  product      Product    @relation(fields: [productId], references: [id])
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@map("stocks")
}

model Review {
  id               String    @id @default(uuid())
  userId           String?   @map("user_id")
  productId        String    @map("product_id")
  rating           Int
  comment          String?
  images           String[]
  isVerified       Boolean   @default(false) @map("is_verified")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  customerName     String?   @map("customer_name")
  customerLocation String?   @map("customer_location")
  customerImageUrl String?   @map("customer_image_url")
  product          Product   @relation(fields: [productId], references: [id])
  user             User?     @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model ProductImportLog {
  id          String   @id @default(uuid())
  triggeredBy String?  @map("triggered_by")
  status      String
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("product_import_logs")
}

model Order {
  id                    String               @id @default(uuid())
  orderNumber           String               @unique @map("order_number")
  userId                String               @map("user_id")
  status                String               @default("PENDING")
  totalAmount           Decimal              @map("total_amount") @db.Decimal(12, 2)
  taxAmount             Decimal              @map("tax_amount") @db.Decimal(12, 2)
  shippingAmount        Decimal              @map("shipping_amount") @db.Decimal(12, 2)
  addressId             String               @map("address_id")
  couponId              String?              @map("coupon_id")
  paymentStatus         String               @default("UNPAID") @map("payment_status")
  paymentMethod         String?              @map("payment_method")
  trackingNumber        String?              @map("tracking_number")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  deletedAt             DateTime?            @map("deleted_at")
  billingSnapshot       Json?                @map("billing_snapshot")
  currencyId            String               @map("currency_id")
  notes                 Json?
  orderContext          Json?                @map("order_context")
  paymentDetails        Json?                @map("payment_details")
  pricingSummary        Json?                @map("pricing_summary")
  shippingDetails       Json?                @map("shipping_details")
  shippingSnapshot      Json?                @map("shipping_snapshot")
  courierPartner        String?              @map("courier_partner")
  creditAPR             Decimal?             @map("credit_apr") @db.Decimal(5, 2)
  creditTerm            Int?                 @map("credit_term")
  deliveryMethod        String?              @map("delivery_method")
  downPayment           Decimal?             @map("down_payment") @db.Decimal(10, 2)
  estimatedDeliveryDate DateTime?            @map("estimated_delivery_date")
  transactionRef        String?              @map("transaction_ref")
  deliveredDate         DateTime?            @map("delivered_date")
  processingDate        DateTime?            @map("processing_date")
  shippedDate           DateTime?            @map("shipped_date")
  trackingTimeline      Json?                @map("tracking_timeline")
  shipperBookingId      String?              @map("shipper_booking_id")
  shipperLabelUrl       String?              @map("shipper_label_url")
  items                 OrderItem[]
  history               OrderStatusHistory[]
  address               Address              @relation(fields: [addressId], references: [id])
  currency              Currency             @relation(fields: [currencyId], references: [id])
  user                  User                 @relation(fields: [userId], references: [id])
  coupon                Coupon?              @relation(fields: [couponId], references: [id])
  purchase_orders       purchase_orders?
  transactions          Transaction[]
  returnRequests        ReturnRequest[]

  @@index([currencyId])
  @@map("orders")
}

model OrderItem {
  id                String  @id @default(uuid())
  orderId           String  @map("order_id")
  productId         String  @map("product_id")
  quantity          Int
  price             Decimal @db.Decimal(10, 2)
  inventorySnapshot Json?   @map("inventory_snapshot")
  pricingSnapshot   Json?   @map("pricing_snapshot")
  sku               String?
  order             Order   @relation(fields: [orderId], references: [id])
  product           Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model RFQ {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  status          String           @default("SUBMITTED")
  notes           String?
  deadline        DateTime?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  purchase_orders purchase_orders?
  items           RFQItem[]
  user            User             @relation(fields: [userId], references: [id])

  @@map("rfqs")
}

model RFQItem {
  id          String   @id @default(uuid())
  rfqId       String   @map("rfq_id")
  productId   String   @map("product_id")
  quantity    Int
  quotedPrice Decimal? @map("quoted_price") @db.Decimal(10, 2)
  product     Product  @relation(fields: [productId], references: [id])
  rfq         RFQ      @relation(fields: [rfqId], references: [id])

  @@map("rfq_items")
}

model SupportTicket {
  id           String          @id @default(uuid())
  subject      String
  category     String
  priority     String          @default("MEDIUM")
  status       String          @default("OPEN")
  userId       String          @map("user_id")
  assignedToId String?         @map("assigned_to_id")
  attachments  String[]        @default([])
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")
  user         User            @relation("UserTickets", fields: [userId], references: [id])
  assignedTo   User?           @relation("AssignedTickets", fields: [assignedToId], references: [id])
  messages     TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id          String        @id @default(uuid())
  ticketId    String        @map("ticket_id")
  userId      String        @map("user_id")
  message     String
  isAdmin     Boolean       @default(false) @map("is_admin")
  attachments String[]      @default([])
  createdAt   DateTime      @default(now()) @map("created_at")
  ticket      SupportTicket @relation(fields: [ticketId], references: [id])
  user        User          @relation(fields: [userId], references: [id])

  @@map("ticket_messages")
}

model ShippingZone {
  id                String         @id @default(uuid())
  name              String         @unique
  countries         String[]
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")
  countryId         String?        @map("country_id")
  volumetricDivisor Int            @default(5000) @map("volumetric_divisor")
  rates             ShippingRate[]
  country           Country?       @relation(fields: [countryId], references: [id])

  @@index([countryId])
  @@map("shipping_zones")
}

model ShippingRate {
  id              String       @id @default(uuid())
  zoneId          String       @map("zone_id")
  cityName        String?      @map("city_name")
  baseRate        Decimal      @map("base_rate") @db.Decimal(10, 2)
  estimatedDays   String?      @map("estimated_days")
  minWeight       Decimal      @default(0) @map("min_weight") @db.Decimal(10, 2)
  volumeIncrement Decimal      @default(0) @map("volume_increment") @db.Decimal(10, 2)
  weightIncrement Decimal      @default(0) @map("weight_increment") @db.Decimal(10, 2)
  zone            ShippingZone @relation(fields: [zoneId], references: [id])

  @@map("shipping_rates")
}

model Media {
  id        String   @id @default(uuid())
  filename  String
  url       String   @unique
  mimetype  String
  size      Int
  key       String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("media_assets")
}

model CMSPage {
  id               String       @id @default(uuid())
  title            String
  slug             String       @unique
  content          String?
  isActive         Boolean      @default(true) @map("is_active")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")
  featuredImageUrl String?      @map("featured_image_url")
  contentJson      Json?        @map("content_json")
  schema           String?      @map("schema_json")
  logs             CMSLog[]
  versions         CMSVersion[]

  @@map("cms_pages")
}

model CMSVersion {
  id          String   @id @default(uuid())
  pageId      String   @map("page_id")
  content     String
  version     Int
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  contentJson Json?    @map("content_json")
  creator     User     @relation(fields: [createdBy], references: [id])
  page        CMSPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@map("cms_page_versions")
}

model CMSLog {
  id        String   @id @default(uuid())
  pageId    String?  @map("page_id")
  userId    String   @map("user_id")
  action    String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")
  page      CMSPage? @relation(fields: [pageId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("cms_logs")
}

model BlogCategory {
  id          String         @id @default(uuid())
  name        String         @unique
  slug        String         @unique
  description String?
  parentId    String?        @map("parent_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")
  parent      BlogCategory?  @relation("BlogCategoryHierarchy", fields: [parentId], references: [id])
  children    BlogCategory[] @relation("BlogCategoryHierarchy")
  posts       BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id               String        @id @default(uuid())
  title            String
  slug             String        @unique
  excerpt          String?
  content          String
  featuredImageUrl String?       @map("featured_image_url")
  metaTitle        String?       @map("meta_title")
  metaDescription  String?       @map("meta_description")
  categoryId       String?       @map("category_id")
  tags             String[]
  status           String        @default("DRAFT")
  isFeatured       Boolean       @default(false) @map("is_featured")
  publishedAt      DateTime?     @map("published_at")
  authorId         String        @map("author_id")
  viewCount        Int           @default(0) @map("view_count")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")
  author           User          @relation(fields: [authorId], references: [id])
  category         BlogCategory? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([status, publishedAt])
  @@index([slug])
  @@map("blog_posts")
}

model BlogSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("blog_subscribers")
}

model PredefinedReport {
  id          String      @id @default(uuid())
  name        String
  description String?
  sqlQuery    String      @map("sql_query")
  category    String
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  logs        ReportLog[]

  @@map("predefined_reports")
}

model ReportLog {
  id        String            @id @default(uuid())
  reportId  String?           @map("report_id")
  userId    String            @map("user_id")
  format    String            @default("csv")
  status    String            @default("success")
  errorMsg  String?           @map("error_msg")
  createdAt DateTime          @default(now()) @map("created_at")
  report    PredefinedReport? @relation(fields: [reportId], references: [id])
  user      User              @relation(fields: [userId], references: [id])

  @@map("report_logs")
}

model Banner {
  id        String    @id @default(uuid())
  title     String?
  imageUrl  String    @map("image_url")
  linkUrl   String?   @map("link_url")
  order     Int       @default(0)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("banners")
}

model Transaction {
  id                    String   @id @default(uuid())
  orderId               String   @map("order_id")
  userId                String   @map("user_id")
  amount                Decimal  @db.Decimal(12, 2)
  status                String   @default("PENDING")
  type                  String   @default("PAYMENT")
  method                String   @default("ONLINE")
  providerTransactionId String?  @map("provider_transaction_id")
  metadata              Json?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  currencyId            String   @map("currency_id")
  currency              Currency @relation(fields: [currencyId], references: [id])
  order                 Order    @relation(fields: [orderId], references: [id])
  user                  User     @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([currencyId])
  @@map("transactions")
}

model OrderStatusHistory {
  id            String   @id @default(uuid())
  orderId       String   @map("order_id")
  status        String
  notes         String?
  changedBy     String?  @map("changed_by")
  createdAt     DateTime @default(now()) @map("created_at")
  changedByUser User?    @relation(fields: [changedBy], references: [id])
  order         Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_status_history")
}

model Cart {
  id         String     @id @default(uuid())
  userId     String?    @map("user_id")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  guestToken String?    @map("guest_token")
  status     String     @default("ACTIVE")
  items      CartItem[]
  user       User?      @relation(fields: [userId], references: [id])

  @@unique([userId, status], name: "unique_active_user_cart")
  @@index([guestToken])
  @@index([userId, status])
  @@index([status])
  @@map("carts")
}

model CartItem {
  id            String   @id @default(uuid())
  cartId        String   @map("cart_id")
  productId     String   @map("product_id")
  quantity      Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  priceSnapshot Decimal? @map("price_snapshot") @db.Decimal(10, 2)
  cart          Cart     @relation(fields: [cartId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([productId])
  @@map("cart_items")
}

model Wishlist {
  id        String         @id @default(uuid())
  userId    String         @unique @map("user_id")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  items     WishlistItem[]
  user      User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(uuid())
  wishlistId String   @map("wishlist_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")
  product    Product  @relation(fields: [productId], references: [id])
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([productId])
  @@map("wishlist_items")
}

model GlobalSettings {
  id                String   @id @default(uuid())
  storeName         String   @default("Paperland") @map("store_name")
  contactEmail      String   @default("admin@paperland.com.pk") @map("contact_email")
  maintenanceMode   Boolean  @default(false) @map("maintenance_mode")
  twoFactorEnabled  Boolean  @default(true) @map("two_factor_enabled")
  smtpHost          String   @default("smtp.sendgrid.net") @map("smtp_host")
  smtpPort          Int      @default(587) @map("smtp_port")
  smtpEncryption    String   @default("TLS") @map("smtp_encryption")
  smtpUser          String?  @map("smtp_user")
  smtpPass          String?  @map("smtp_pass")
  senderName        String   @default("Paperland Support") @map("sender_name")
  senderEmail       String   @default("no-reply@paperland.com.pk") @map("sender_email")
  storeSlogan       String?  @map("store_slogan") @default("School Se Office Tak")
  backupS3Enabled   Boolean  @default(false) @map("backup_s3_enabled")
  backupS3Bucket    String?  @map("backup_s3_bucket")
  backupS3Region    String?  @map("backup_s3_region")
  backupS3AccessKey String?  @map("backup_s3_access_key")
  backupS3SecretKey String?  @map("backup_s3_secret_key")
  backupS3Path      String?  @map("backup_s3_path")
  backupFtpEnabled  Boolean  @default(false) @map("backup_ftp_enabled")
  backupFtpHost     String?  @map("backup_ftp_host")
  backupFtpPort     Int      @default(21) @map("backup_ftp_port")
  backupFtpUser     String?  @map("backup_ftp_user")
  backupFtpPass     String?  @map("backup_ftp_pass")
  backupFtpPath     String?  @map("backup_ftp_path")
  updatedAt         DateTime @updatedAt @map("updated_at")
  seoDescription    String?  @map("seo_description")
  seoKeywords       String?  @map("seo_keywords")
  seoScriptsBody    String?  @map("seo_scripts_body")
  seoScriptsHeader  String?  @map("seo_scripts_header")
  seoTitle          String?  @map("seo_title")
  sitemapUrl        String?  @map("sitemap_url")
  backupS3Endpoint  String?  @map("backup_s3_endpoint")
  sitemapContent    String?  @map("sitemap_content")
  
  // Bank Details for Manual Payments
  bankAccountName   String?  @map("bank_account_name")
  bankAccountNumber String?  @map("bank_account_number")
  bankName          String?  @map("bank_name")
  bankIban          String?  @map("bank_iban")
  bankSwiftCode     String?  @map("bank_swift_code")

  @@map("global_settings")
}

model PaymentGateway {
  id             String   @id @default(uuid())
  name           String
  identifier     String   @unique // e.g. 'jazzcash', 'easypaisa', 'bank_transfer'
  type           String   @default("WALLET") // WALLET, CARD, BANK_TRANSFER, BNPL
  isActive       Boolean  @default(true) @map("is_active")
  config         Json?    // For API keys, Merchant IDs etc
  instructions   String?  @db.Text
  feePercentage  Decimal  @default(0) @db.Decimal(5, 2) @map("fee_percentage")
  feeFixed       Decimal  @default(0) @db.Decimal(10, 2) @map("fee_fixed")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("payment_gateways")
}

model ShippingCourier {
  id           String   @id @default(uuid())
  name         String   @unique // 'TCS', 'Leopards', 'M&P'
  identifier     String   @unique // 'tcs', 'leopards', 'mnp'
  isActive     Boolean  @default(true) @map("is_active")
  config       Json?    // For API keys, Merchant IDs etc
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("shipping_couriers")
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  performedBy String?  @map("performed_by")
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  entityId    String?  @map("entity_id")
  entityType  String   @map("entity_type")
  ip          String?
  userAgent   String?  @map("user_agent")
  metadata    Json?
  performer   User?    @relation(fields: [performedBy], references: [id])

  @@index([entityType, entityId])
  @@index([performedBy])
  @@map("audit_logs")
}

model HomepageSection {
  id           String                @id @default(uuid())
  internalName String                @map("internal_name")
  displayTitle String?               @map("display_title")
  subtitle     String?
  type         String                @default("GRID")
  sortOrder    Int                   @default(0) @map("sort_order")
  isActive     Boolean               @default(true) @map("is_active")
  ctaLabel     String?               @map("cta_label")
  ctaLink      String?               @map("cta_link")
  styles       Json?
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  items        HomepageSectionItem[]

  @@map("homepage_sections")
}

model HomepageSectionItem {
  id                String          @id @default(uuid())
  sectionId         String          @map("section_id")
  productId         String?         @map("product_id")
  customTitle       String?         @map("custom_title")
  customImage       String?         @map("custom_image")
  customLink        String?         @map("custom_link")
  isFeaturedLarge   Boolean         @default(false) @map("is_featured_large")
  sortOrder         Int             @default(0) @map("sort_order")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  customDescription String?         @map("custom_description")
  isActive          Boolean         @default(true) @map("is_active")
  customSubtitle    String?         @map("custom_subtitle")
  product           Product?        @relation(fields: [productId], references: [id])
  section           HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("homepage_section_items")
}

model CrossReference {
  id              String   @id @default(uuid())
  productId       String   @map("product_id")
  targetProductId String   @map("target_product_id")
  relationType    String   @default("COMPATIBLE")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  product         Product  @relation("SourceProduct", fields: [productId], references: [id])
  targetProduct   Product  @relation("TargetProduct", fields: [targetProductId], references: [id])

  @@unique([productId, targetProductId, relationType])
  @@map("cross_references")
}

model PendingRegistration {
  id               String    @id @default(uuid())
  email            String    @unique
  otpCode          String?   @map("otp_code")
  otpExpiry        DateTime? @map("otp_expiry")
  emailVerified    Boolean   @default(false) @map("email_verified")
  passwordHash     String?   @map("password_hash")
  firstName        String?   @map("first_name")
  lastName         String?   @map("last_name")
  phoneNumber      String?   @map("phone_number")
  phoneCountryCode String?   @map("phone_country_code")
  city             String?
  country          String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  state            String?
  zipCode          String?   @map("zip_code")

  @@map("pending_registrations")
}

model b2b_team_members {
  id                      String     @id
  user_id                 String     @unique
  b2b_profile_id          String
  role                    String     @default("BUYER")
  status                  String     @default("ACTIVE")
  created_at              DateTime   @default(now())
  updated_at              DateTime
  order_approval_limit    Decimal?   @db.Decimal(12, 2)
  requires_admin_approval Boolean    @default(false)
  b2b_profiles            B2BProfile @relation(fields: [b2b_profile_id], references: [id], onDelete: Cascade)
  users                   User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model custom_catalog_items {
  id                String          @id
  catalog_id        String
  product_id        String
  custom_price      Decimal         @db.Decimal(10, 2)
  minimum_quantity  Int             @default(1)
  buyer_part_number String?
  created_at        DateTime        @default(now())
  updated_at        DateTime
  custom_catalogs   custom_catalogs @relation(fields: [catalog_id], references: [id], onDelete: Cascade)
  products          Product         @relation(fields: [product_id], references: [id])

  @@unique([catalog_id, product_id])
}

model custom_catalogs {
  id                   String                 @id
  name                 String
  description          String?
  b2b_profile_id       String
  is_active            Boolean                @default(true)
  valid_from           DateTime?
  valid_until          DateTime?
  created_at           DateTime               @default(now())
  updated_at           DateTime
  custom_catalog_items custom_catalog_items[]
  b2b_profiles         B2BProfile             @relation(fields: [b2b_profile_id], references: [id])
}

model purchase_orders {
  id             String     @id
  po_number      String     @unique
  b2b_profile_id String
  user_id        String
  status         String     @default("PENDING_APPROVAL")
  amount         Decimal    @db.Decimal(12, 2)
  notes          String?
  document_url   String?
  rfq_id         String?    @unique
  order_id       String?    @unique
  created_at     DateTime   @default(now())
  updated_at     DateTime
  b2b_profiles   B2BProfile @relation(fields: [b2b_profile_id], references: [id])
  orders         Order?     @relation(fields: [order_id], references: [id])
  rfqs           RFQ?       @relation(fields: [rfq_id], references: [id])
  users          User       @relation(fields: [user_id], references: [id])
}

model DiscountTier {
  id              String   @id @default(uuid())
  name            String   @unique
  discountPercent Decimal  @map("discount_percent") @db.Decimal(5, 2)
  isActive        Boolean  @default(true) @map("is_active")
  exemptSkus      String[] @default([]) @map("exempt_skus")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  b2bProfiles B2BProfile[]

  @@map("discount_tiers")
}

model ProductDiscountOverride {
  id              String   @id @default(uuid())
  b2bProfileId    String   @map("b2b_profile_id")
  productId       String   @map("product_id")
  discountPercent Decimal  @map("discount_percent") @db.Decimal(5, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  b2bProfile B2BProfile @relation(fields: [b2bProfileId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([b2bProfileId, productId])
  @@index([b2bProfileId])
  @@index([productId])
  @@map("product_discount_overrides")
}

model Coupon {
  id                String    @id @default(uuid())
  code              String    @unique
  discountType      String    @map("discount_type") // PERCENTAGE, FIXED
  discountValue     Decimal   @map("discount_value") @db.Decimal(10, 2)
  minOrderAmount    Decimal?  @map("min_order_amount") @db.Decimal(10, 2)
  maxDiscountAmount Decimal?  @map("max_discount_amount") @db.Decimal(10, 2)
  startDate         DateTime  @map("start_date")
  endDate           DateTime  @map("end_date")
  usageLimit        Int?      @map("usage_limit")
  usedCount         Int       @default(0) @map("used_count")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  orders            Order[]

  @@map("coupons")
}

model ReturnRequest {
  id             String       @id @default(uuid())
  orderId        String       @map("order_id")
  userId         String       @map("user_id")
  status         String       @default("PENDING") // PENDING, APPROVED, PICKED, REFUNDED, REJECTED
  reason         String
  notes          String?
  trackingNumber String?      @map("tracking_number")
  refundAmount   Decimal?     @map("refund_amount") @db.Decimal(10, 2)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  
  order          Order        @relation(fields: [orderId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  items          ReturnItem[]

  @@map("return_requests")
}

model ReturnItem {
  id              String        @id @default(uuid())
  returnRequestId String        @map("return_request_id")
  productId       String        @map("product_id")
  quantity        Int
  condition       String?       // Working, Damaged, Dead, Wrong Item
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@map("return_items")
}
