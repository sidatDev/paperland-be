// New B2BCompanyDetails model for multi-step signup
model B2BCompanyDetails {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Company Information (Step 4)
  companyName          String   @map("company_name")
  registrationCountry  String   @map("registration_country") // KSA, UAE, PAK
  taxId                String   @map("tax_id") // CR Number, Trade License, NTN
  registrationDate     DateTime @map("registration_date")
  companyAddress       String   @db.Text @map("company_address")
  registrationProofUrl String   @map("registration_proof_url") // S3/MinIO URL
  doingBusinessAs      String?  @map("doing_business_as")
  
  // Contact Details (Step 5)
  primaryContactName   String   @map("primary_contact_name")
  jobTitle             String   @map("job_title") // Dropdown value or "Other - Custom Text"
  contactPhone         String   @map("contact_phone")
  contactCountryCode   String   @map("contact_country_code") // +966, +971, +92
  billingEmail         String   @map("billing_email")
  shippingAddress      String   @db.Text @map("shipping_address")
  
  // Accounts Payable Contact (Step 5)
  apContactName        String   @map("ap_contact_name")
  apPhone              String   @map("ap_phone")
  apCountryCode        String   @map("ap_country_code")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@map("b2b_company_details")
}

